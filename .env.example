# FM2note Environment Variables
#
# As of v1.4.12, .env holds ONLY sensitive credentials. All non-secret
# configuration (vault_path, podcast_dir, asr_engine, summary_provider,
# summary_model, summary_cooldown, summary_base_url, log_level, etc.) lives in
# config/config.yaml and is editable from the Web UI's 设置 page. Putting any
# of those in .env would silently shadow Web UI edits — see CLAUDE.md Version
# History for the OBSIDIAN_VAULT_PATH regression that motivated this split.
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ============ Required ============

# DashScope API Key (shared by FunASR / Paraformer / TingWu engines)
# Get it from: https://dashscope.console.aliyun.com/
export DASHSCOPE_API_KEY=sk-xxx

# ============ Optional: AI Summary keys ============

# Poe API Key (for AI summaries via Poe)
# Get it from: https://poe.com/api_key
export POE_API_KEY=

# OpenAI API Key (for whisper_api engine and/or OpenAI summaries)
# Get it from: https://platform.openai.com/api-keys
export OPENAI_API_KEY=

# ============ Optional: Aliyun Balance ============

# RAM 子账号 AK/SK，只挂 AliyunBSSReadOnlyAccess 权限（财务只读）
# 配置后顶部导航会显示余额徽章；可用现金余额 <¥10 弹出充值提醒
# 创建 RAM 用户：https://ram.console.aliyun.com/users
export ALIYUN_ACCESS_KEY_ID=
export ALIYUN_ACCESS_KEY_SECRET=

# ============ Optional: Other ============

# TingWu App ID (only needed if asr_engine=tingwu)
export TINGWU_APP_ID=

# ============ Optional: Shared transcript cache (v1.4.16) ============

# If you and someone else (e.g. partner) run FM2note independently with
# overlapping subscriptions, set these to point at a self-hosted sidecar
# (see server/docker-compose.cache.yaml). When configured, the pipeline
# uploads finished notes and the RSS poller checks the cache before
# transcribing — saves money when both sides already have the same episode.
# Leave both empty for single-user deployments.
export SHARED_CACHE_URL=
export SHARED_CACHE_TOKEN=
