# FM2note Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ============ Required ============

# DashScope API Key (shared by FunASR / Paraformer / TingWu engines)
# Get it from: https://dashscope.console.aliyun.com/
export DASHSCOPE_API_KEY=sk-xxx

# Obsidian vault path (absolute path to your vault)
export OBSIDIAN_VAULT_PATH="/path/to/obsidian/vault"

# ============ Optional ============

# TingWu App ID (only needed if asr_engine=tingwu)
# Get it from: https://tingwu.console.aliyun.com/
export TINGWU_APP_ID=

# Poe API Key (for AI summaries via Poe)
# Get it from: https://poe.com/api_key
export POE_API_KEY=

# OpenAI API Key (for whisper_api engine or future OpenAI summarizer)
# Get it from: https://platform.openai.com/api-keys
export OPENAI_API_KEY=

# Log level: DEBUG | INFO | WARNING | ERROR
export LOG_LEVEL=INFO

# Poe summary model (default: GPT-5.4)
export SUMMARY_MODEL=GPT-5.4

# Poe API call interval in seconds (default: 60)
export SUMMARY_COOLDOWN=60
