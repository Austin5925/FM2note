# FM2note Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ============ Required ============

# DashScope API Key (shared by FunASR / Paraformer / TingWu engines)
# Get it from: https://dashscope.console.aliyun.com/
export DASHSCOPE_API_KEY=sk-xxx

# Obsidian vault path (absolute path to your vault)
export OBSIDIAN_VAULT_PATH="/path/to/obsidian/vault"

# ============ Optional: AI Summary ============

# Summary provider: auto | poe | openai | none
# "auto" detects based on which API key is set
export SUMMARY_PROVIDER=auto

# Poe API Key (for AI summaries via Poe)
# Get it from: https://poe.com/api_key
export POE_API_KEY=

# OpenAI API Key (for whisper_api engine and/or OpenAI summaries)
# Get it from: https://platform.openai.com/api-keys
export OPENAI_API_KEY=

# Summary model (leave empty for provider default)
# Poe default: GPT-5.4 | OpenAI default: gpt-4o-mini
export SUMMARY_MODEL=

# OpenAI-compatible base URL (for DeepSeek, Groq, Ollama, etc.)
# Leave empty for official OpenAI endpoint
export SUMMARY_BASE_URL=

# API call interval in seconds (rate limiting, default: 60)
export SUMMARY_COOLDOWN=60

# ============ Optional: Other ============

# TingWu App ID (only needed if asr_engine=tingwu)
export TINGWU_APP_ID=

# Log level: DEBUG | INFO | WARNING | ERROR
export LOG_LEVEL=INFO
