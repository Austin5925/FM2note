# DashScope API Key（FunASR / Paraformer / 通义听悟共用）
export DASHSCOPE_API_KEY=sk-xxx

# 通义听悟 AppId（仅 asr_engine=tingwu 时需要）
export TINGWU_APP_ID=tw_xxx

# Poe API（AI 摘要，可选）
export POE_API_KEY=

# OpenAI Whisper（备选）
export OPENAI_API_KEY=

# Obsidian vault 路径（本地 Mac 绝对路径）
export OBSIDIAN_VAULT_PATH="/path/to/obsidian/vault"

# 日志
export LOG_LEVEL=INFO
